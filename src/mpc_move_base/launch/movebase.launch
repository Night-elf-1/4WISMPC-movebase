<launch>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen" clear_params="true">
        <!-- 使用 global_planner 作为全局规划器，并启用 A* -->
        <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
        <rosparam file="$(find mpc_move_base)/param/global_planner_params.yaml" command="load" ns="GlobalPlanner" />
        <!-- 使用 4WIS NMPC 自定义局部规划器 -->
        <param name="base_local_planner" value="mpc_local_planner/MpcLocalPlanner"/>
        <rosparam file="$(find mpc_move_base)/param/costmap_common_params.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find mpc_move_base)/param/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find mpc_move_base)/param/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find mpc_move_base)/param/global_costmap_params.yaml" command="load" />
        <rosparam file="$(find mpc_local_planner)/param/mpc_local_planner_params.yaml" command="load" />
    </node>

</launch>
<launch>
    <param name="use_sim_time" value="true"/>
    <!-- 设置地图的配置文件 -->
    <arg name="map" default="hamstermaps.yaml" />
    <!-- 运行地图服务器，并且加载设置的地图-->
    <node name="map_server" pkg="map_server" type="map_server" args="$(find mpc_move_base)/maps/$(arg map)"/>
    <!-- 启动AMCL节点 -->
    <include file="$(find mpc_move_base)/launch/amcl.launch" />

    <!-- 运行move_base节点 -->
    <include file="$(find mpc_move_base)/launch/movebase.launch" />
    <!-- 运行rviz -->
    <!-- <node pkg="rviz" type="rviz" name="rviz" args="-d $(find mpc_move_base)/rviz/nav.rviz" /> -->

</launch>
<?xml version='1.0' encoding='UTF-8'?>
<launch>
  <arg name="robot_name"/>
  <arg name="config_file"/>

  <!-- 是否由 twist_sub_node 发布轮速/转向指令；
       如果使用外部 MPC 直接控制轮子，设为 false 以避免话题冲突 -->
  <arg name="publish_wheel_commands" default="true"/>

  <!-- 是否使用 twist_sub_node 内部的自定义里程计；
       若使用 gazebo_ros_p3d 等官方 ground truth 里程计，设为 false -->
  <arg name="publish_odom_tf" default="true"/>

  <!-- Load joint controller configurations from YAML file to parameter server -->
  <rosparam file="$(find car_model)/config/$(arg config_file)" command="load"/>

  <!-- load controllers -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
        output="screen" ns="/$(arg robot_name)" args="joint_state_controller rear_right_str_controller rear_right_velocity_controller rear_left_str_controller rear_left_velocity_controller front_right_str_controller front_right_velocity_controller front_left_str_controller front_left_svelocity_controller"/>

  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"
      respawn="true" output="screen">
      <remap from="/joint_states" to="/$(arg robot_name)/joint_states" />
  </node>

  <rosparam file="$(find car_model)/config/speed_distribution_node.yaml" command="load"/>
  <node pkg="car_model" name="test_yaml_node" type="twist_sub_node" output="screen">
    <param name="publish_odom_tf" value="$(arg publish_odom_tf)"/>
    <!-- 当外部 MPC 接管时，把 twist_sub_node 的轮速/转向指令重映射到无效话题，
         避免与 MPC 发布的控制指令冲突。publish_odom_tf 控制是否发布自定义里程计/TF。 -->
    <remap unless="$(arg publish_wheel_commands)" from="/smart/front_left_svelocity_controller/command" to="/smart/front_left_svelocity_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/front_left_str_controller/command" to="/smart/front_left_str_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/front_right_velocity_controller/command" to="/smart/front_right_velocity_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/front_right_str_controller/command" to="/smart/front_right_str_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/rear_left_velocity_controller/command" to="/smart/rear_left_velocity_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/rear_left_str_controller/command" to="/smart/rear_left_str_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/rear_right_velocity_controller/command" to="/smart/rear_right_velocity_controller/command_unused"/>
    <remap unless="$(arg publish_wheel_commands)" from="/smart/rear_right_str_controller/command" to="/smart/rear_right_str_controller/command_unused"/>
  </node>  
  <!-- <node name="cmdvel2gazebo" pkg="car_model" type="cmdvel2gazebo.py" respawn="true" output="screen"/>   -->

</launch>
